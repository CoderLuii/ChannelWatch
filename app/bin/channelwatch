#!/usr/bin/python
"""ChannelWatch container helper."""

from __future__ import annotations

import os
from pathlib import Path
import runpy
import sys


def _app_dir() -> Path:
    configured = os.environ.get("CHANNELWATCH_APP_DIR", "").strip()
    if configured:
        return Path(configured)

    image_dir = Path(os.environ.get("CHANNELWATCH_IMAGE_APP_DIR", "/app"))
    config_dir = Path(os.environ.get("CONFIG_PATH", "/config"))
    try:
        sys.path.insert(0, str(image_dir))
        from core import __version__
        from core.helpers.migration import CURRENT_SCHEMA_VERSION
        from core.update_center import resolve_active_app_dir

        return resolve_active_app_dir(
            config_dir=config_dir,
            image_app_dir=image_dir,
            image_version=__version__,
            settings_schema_version=CURRENT_SCHEMA_VERSION,
        ).app_dir
    except Exception:
        return image_dir


def main() -> int:
    if len(sys.argv) >= 2 and sys.argv[1] == "doctor":
        app_dir = _app_dir()
        if app_dir.is_dir():
            os.chdir(app_dir)
        python_path = os.environ.get("PYTHONPATH", "")
        path_parts = [str(app_dir)]
        if python_path:
            path_parts.append(python_path)
        os.environ["PYTHONPATH"] = os.pathsep.join(path_parts)
        sys.argv = ["python -m core.cli.doctor", *sys.argv[2:]]
        runpy.run_module("core.cli.doctor", run_name="__main__")
        return 0

    print("Usage: channelwatch doctor [ARGS...]", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
